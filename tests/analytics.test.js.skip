/**
 * Testes de Analytics e Métricas - API
 * Testa sistema de coleta de analytics, métricas de uso e relatórios
 */

const axios = require('axios');
const { trackUser, trackItinerary, cleanupTestData } = require('./helpers/testCleanup');

const API_URL = process.env.API_URL || 'http://localhost:3000';

describe('Analytics - Testes Extensivos', () => {
  let authToken, userId;
  let disabledToken, disabledUserId;
  let itineraryId;

  beforeAll(async () => {
    // Usuário com analytics ativado
    const response = await axios.post(`${API_URL}/api/auth/signup`, {
      name: 'Analytics Test User',
      email: `analytics-test-${Date.now()}@test.com`,
      password: 'Senha@123',
      acceptedTerms: true,
      analyticsEnabled: true
    });
    authToken = response.data.accessToken;
    userId = response.data.user._id;
    trackUser(userId);

    // Usuário com analytics desativado
    const disabledRes = await axios.post(`${API_URL}/api/auth/signup`, {
      name: 'Analytics Disabled User',
      email: `analytics-disabled-${Date.now()}@test.com`,
      password: 'Senha@123',
      acceptedTerms: true,
      analyticsEnabled: false
    });
    disabledToken = disabledRes.data.accessToken;
    disabledUserId = disabledRes.data.user._id;
    trackUser(disabledUserId);

    // Criar roteiro para testes
    const itRes = await axios.post(`${API_URL}/api/roteiros`, {
      title: 'Roteiro Analytics Test',
      destination: { city: 'Berlim', country: 'Alemanha' },
      startDate: new Date('2027-05-01'),
      endDate: new Date('2027-05-05'),
      duration: 5,
      budget: { level: 'medio', estimatedTotal: 3500, currency: 'EUR' }
    }, {
      headers: { Authorization: `Bearer ${authToken}` }
    });
    itineraryId = itRes.data.itinerary._id;
    trackItinerary(itineraryId);
  });

  afterAll(async () => {
    await cleanupTestData({
      emailPatterns: [/@test\.com$/],
      titlePatterns: [/Analytics/i]
    });
  });

  describe('POST /api/analytics/event - Registrar Evento', () => {
    afterEach(async () => {
      // 🧹 Limpar eventos criados (se houver endpoint de limpeza)
      try {
        await axios.delete(`${API_URL}/api/analytics/events/recent`, {
          headers: { Authorization: `Bearer ${authToken}` }
        });
      } catch (error) {
        // Endpoint pode não existir, ignorar
      }
    });

    test('✅ Deve registrar evento de usuário com analytics ativado', async () => {
      const response = await axios.post(`${API_URL}/api/analytics/event`, {
        eventName: 'itinerary_viewed',
        eventData: {
          itineraryId,
          source: 'dashboard'
        },
        timestamp: new Date().toISOString()
      }, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      expect([200, 201, 204]).toContain(response.status);
    });

    test('✅ Deve aceitar diferentes tipos de eventos', async () => {
      const events = [
        { eventName: 'screen_view', eventData: { screen: 'Dashboard' } },
        { eventName: 'button_click', eventData: { button: 'create_itinerary' } },
        { eventName: 'feature_used', eventData: { feature: 'ai_generation' } },
        { eventName: 'search_performed', eventData: { query: 'Paris' } }
      ];

      for (const event of events) {
        const response = await axios.post(`${API_URL}/api/analytics/event`, {
          ...event,
          timestamp: new Date().toISOString()
        }, {
          headers: { Authorization: `Bearer ${authToken}` }
        });

        expect([200, 201, 204]).toContain(response.status);
      }
    });

    test('✅ Evento de usuário com analytics desativado não deve ser processado', async () => {
      const response = await axios.post(`${API_URL}/api/analytics/event`, {
        eventName: 'test_event',
        eventData: { test: true },
        timestamp: new Date().toISOString()
      }, {
        headers: { Authorization: `Bearer ${disabledToken}` }
      });

      // Deve aceitar mas não processar (retorna 204 ou similar)
      expect([200, 201, 204]).toContain(response.status);
    });

    test('❌ Não deve registrar evento sem nome', async () => {
      try {
        await axios.post(`${API_URL}/api/analytics/event`, {
          eventData: { test: true },
          timestamp: new Date().toISOString()
        }, {
          headers: { Authorization: `Bearer ${authToken}` }
        });
        fail('Deveria ter lançado erro');
      } catch (error) {
        expect(error.response.status).toBe(400);
      }
    });

    test('❌ Não deve registrar evento sem timestamp', async () => {
      try {
        await axios.post(`${API_URL}/api/analytics/event`, {
          eventName: 'test',
          eventData: {}
        }, {
          headers: { Authorization: `Bearer ${authToken}` }
        });
        fail('Deveria ter lançado erro');
      } catch (error) {
        expect(error.response.status).toBe(400);
      }
    });

    test('❌ Não deve registrar evento sem autenticação', async () => {
      try {
        await axios.post(`${API_URL}/api/analytics/event`, {
          eventName: 'unauthorized',
          eventData: {},
          timestamp: new Date().toISOString()
        });
        fail('Deveria ter lançado erro');
      } catch (error) {
        expect(error.response.status).toBe(401);
      }
    });
  });

  describe('GET /api/analytics/dashboard - Dashboard de Métricas', () => {
    test('✅ Usuário admin deve acessar dashboard global', async () => {
      // Tentar buscar dashboard (pode precisar ser admin)
      const response = await axios.get(`${API_URL}/api/analytics/dashboard`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (response.status === 200) {
        expect(response.data).toHaveProperty('metrics');
        expect(response.data.metrics).toHaveProperty('totalUsers');
        expect(response.data.metrics).toHaveProperty('totalItineraries');
        expect(response.data.metrics).toHaveProperty('activeUsers');
      } else if (response.status === 403) {
        // Usuário comum não tem acesso - comportamento esperado
        expect(response.status).toBe(403);
      }
    });

    test('✅ Dashboard deve incluir métricas de período', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/dashboard`, {
        params: {
          startDate: '2024-01-01',
          endDate: '2025-12-31'
        },
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (response.status === 200) {
        expect(response.data).toHaveProperty('period');
        expect(response.data.period.startDate).toBeDefined();
        expect(response.data.period.endDate).toBeDefined();
      }
    });
  });

  describe('GET /api/analytics/user/:userId - Analytics do Usuário', () => {
    test('✅ Usuário deve acessar próprias analytics', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/user/${userId}`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      expect(response.status).toBe(200);
      expect(response.data).toHaveProperty('userStats');
      expect(response.data.userStats).toHaveProperty('totalItineraries');
      expect(response.data.userStats).toHaveProperty('totalTrips');
      expect(response.data.userStats).toHaveProperty('level');
      expect(response.data.userStats).toHaveProperty('xp');
    });

    test('✅ Stats devem incluir atividade recente', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/user/${userId}`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      expect(response.data).toHaveProperty('recentActivity');
      expect(Array.isArray(response.data.recentActivity)).toBe(true);
    });

    test('❌ Usuário não deve acessar analytics de outro usuário', async () => {
      try {
        await axios.get(`${API_URL}/api/analytics/user/${userId}`, {
          headers: { Authorization: `Bearer ${disabledToken}` }
        });
        fail('Deveria ter lançado erro');
      } catch (error) {
        expect(error.response.status).toBeGreaterThanOrEqual(403);
      }
    });

    test('❌ Não deve acessar analytics sem autenticação', async () => {
      try {
        await axios.get(`${API_URL}/api/analytics/user/${userId}`);
        fail('Deveria ter lançado erro');
      } catch (error) {
        expect(error.response.status).toBe(401);
      }
    });
  });

  describe('PUT /api/users/profile - Alterar Preferência de Analytics', () => {
    let originalAnalyticsState;

    beforeAll(async () => {
      // ✅ INDEPENDÊNCIA: Salvar estado original
      const profile = await axios.get(`${API_URL}/api/users/profile`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });
      originalAnalyticsState = profile.data.user.analyticsEnabled;
    });

    afterEach(async () => {
      // ✅ INDEPENDÊNCIA: Restaurar estado após cada teste
      try {
        await axios.put(`${API_URL}/api/users/profile`, {
          analyticsEnabled: originalAnalyticsState
        }, {
          headers: { Authorization: `Bearer ${authToken}` }
        });
      } catch (error) {
        // Ignorar se falhar
      }
    });

    test('✅ Deve desativar analytics', async () => {
      const response = await axios.put(`${API_URL}/api/users/profile`, {
        analyticsEnabled: false
      }, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      expect(response.status).toBe(200);
      expect(response.data.user.analyticsEnabled).toBe(false);
    });

    test('✅ Deve ativar analytics', async () => {
      const response = await axios.put(`${API_URL}/api/users/profile`, {
        analyticsEnabled: true
      }, {
        headers: { Authorization: `Bearer ${disabledToken}` }
      });

      expect(response.status).toBe(200);
      expect(response.data.user.analyticsEnabled).toBe(true);
    });
  });

  describe('Eventos Automáticos do Sistema', () => {
    afterEach(async () => {
      // 🧹 Roteiros criados serão limpos pelo trackItinerary
    });

    test('✅ Criação de roteiro deve gerar evento analytics', async () => {
      // Criar roteiro
      const itRes = await axios.post(`${API_URL}/api/roteiros`, {
        title: 'Roteiro Auto Analytics',
        destination: { city: 'Londres', country: 'UK' },
        startDate: new Date('2027-06-01'),
        endDate: new Date('2027-06-03'),
        duration: 3,
        budget: { level: 'economico', estimatedTotal: 1500, currency: 'GBP' }
      }, {
        headers: { Authorization: `Bearer ${authToken}` }
      });
      trackItinerary(itRes.data.itinerary._id);

      // Verificar se evento foi criado
      const analyticsRes = await axios.get(`${API_URL}/api/analytics/user/${userId}`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (analyticsRes.data.recentActivity) {
        const createEvent = analyticsRes.data.recentActivity.find(a => 
          a.type === 'itinerary_created' || a.eventName === 'itinerary_created'
        );
        // Pode ou não ter dependendo da implementação
      }
    });
  });

  describe('GET /api/analytics/popular - Conteúdo Popular', () => {
    test('✅ Deve retornar destinos mais populares', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/popular/destinations`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (response.status === 200) {
        expect(response.data).toHaveProperty('destinations');
        expect(Array.isArray(response.data.destinations)).toBe(true);
        
        if (response.data.destinations.length > 0) {
          const firstDest = response.data.destinations[0];
          expect(firstDest).toHaveProperty('city');
          expect(firstDest).toHaveProperty('count');
        }
      }
    });

    test('✅ Deve retornar roteiros mais visualizados', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/popular/itineraries`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (response.status === 200) {
        expect(response.data).toHaveProperty('itineraries');
        expect(Array.isArray(response.data.itineraries)).toBe(true);
      }
    });

    test('✅ Deve funcionar sem autenticação (dados agregados)', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/popular/destinations`);

      // Pode ser público ou requerer auth dependendo da implementação
      expect([200, 401]).toContain(response.status);
    });
  });

  describe('Métricas de Uso do App', () => {
    test('✅ Deve registrar tempo de sessão', async () => {
      const response = await axios.post(`${API_URL}/api/analytics/session`, {
        sessionStart: new Date(Date.now() - 300000).toISOString(), // 5 min atrás
        sessionEnd: new Date().toISOString(),
        duration: 300
      }, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      expect([200, 201, 204]).toContain(response.status);
    });

    test('✅ Deve registrar telas visitadas', async () => {
      const screens = ['Dashboard', 'ItineraryDetail', 'Profile', 'Explore'];

      for (const screen of screens) {
        await axios.post(`${API_URL}/api/analytics/event`, {
          eventName: 'screen_view',
          eventData: { screen },
          timestamp: new Date().toISOString()
        }, {
          headers: { Authorization: `Bearer ${authToken}` }
        });
      }

      // Verificar se foi registrado
      const userAnalytics = await axios.get(`${API_URL}/api/analytics/user/${userId}`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      expect(userAnalytics.status).toBe(200);
    });
  });

  describe('Exportação de Dados', () => {
    test('✅ Usuário deve exportar próprios dados analytics', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/export`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (response.status === 200) {
        expect(response.data).toHaveProperty('analytics');
        expect(response.data).toHaveProperty('exportDate');
        expect(response.data).toHaveProperty('userId', userId);
      }
    });

    test('✅ Export deve incluir todos os eventos', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/export`, {
        params: { format: 'json' },
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (response.status === 200 && response.data.events) {
        expect(Array.isArray(response.data.events)).toBe(true);
      }
    });

    test('✅ Deve suportar export em CSV', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/export`, {
        params: { format: 'csv' },
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (response.status === 200) {
        expect(response.headers['content-type']).toContain('csv');
      }
    });
  });

  describe('DELETE /api/analytics/user/:userId - Deletar Dados Analytics', () => {
    let deleteUserId, deleteToken;

    beforeAll(async () => {
      const res = await axios.post(`${API_URL}/api/auth/signup`, {
        name: 'Delete Analytics User',
        email: `delete-analytics-${Date.now()}@test.com`,
        password: 'Senha@123',
        acceptedTerms: true,
        analyticsEnabled: true
      });
      deleteToken = res.data.accessToken;
      deleteUserId = res.data.user._id;
      trackUser(deleteUserId);

      // Registrar alguns eventos
      await axios.post(`${API_URL}/api/analytics/event`, {
        eventName: 'test_event',
        eventData: {},
        timestamp: new Date().toISOString()
      }, {
        headers: { Authorization: `Bearer ${deleteToken}` }
      });
    });

    test('✅ Usuário deve deletar próprios dados analytics', async () => {
      const response = await axios.delete(`${API_URL}/api/analytics/user/${deleteUserId}`, {
        headers: { Authorization: `Bearer ${deleteToken}` }
      });

      expect([200, 204]).toContain(response.status);

      // Verificar que dados foram removidos
      const analyticsRes = await axios.get(`${API_URL}/api/analytics/user/${deleteUserId}`, {
        headers: { Authorization: `Bearer ${deleteToken}` }
      });

      if (analyticsRes.data.recentActivity) {
        expect(analyticsRes.data.recentActivity.length).toBe(0);
      }
    });

    test('❌ Não deve deletar dados de outro usuário', async () => {
      try {
        await axios.delete(`${API_URL}/api/analytics/user/${userId}`, {
          headers: { Authorization: `Bearer ${deleteToken}` }
        });
        fail('Deveria ter lançado erro');
      } catch (error) {
        expect(error.response.status).toBeGreaterThanOrEqual(403);
      }
    });
  });

  describe('Relatórios e Insights', () => {
    test('✅ Deve gerar relatório semanal de uso', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/report/weekly`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (response.status === 200) {
        expect(response.data).toHaveProperty('weekStart');
        expect(response.data).toHaveProperty('weekEnd');
        expect(response.data).toHaveProperty('summary');
      }
    });

    test('✅ Deve gerar insights personalizados', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/insights`, {
        headers: { Authorization: `Bearer ${authToken}` }
      });

      if (response.status === 200) {
        expect(response.data).toHaveProperty('insights');
        expect(Array.isArray(response.data.insights)).toBe(true);
      }
    });
  });

  describe('Privacidade e GDPR', () => {
    test('✅ Dados analytics devem ser anonimizados em relatórios públicos', async () => {
      const response = await axios.get(`${API_URL}/api/analytics/popular/destinations`);

      if (response.status === 200 && response.data.destinations) {
        // Não deve conter IDs de usuários ou info pessoal
        response.data.destinations.forEach(dest => {
          expect(dest).not.toHaveProperty('userId');
          expect(dest).not.toHaveProperty('email');
        });
      }
    });

    test('✅ Usuário com analytics desativado não deve ter eventos registrados', async () => {
      // Tentar registrar evento
      await axios.post(`${API_URL}/api/analytics/event`, {
        eventName: 'should_not_be_saved',
        eventData: {},
        timestamp: new Date().toISOString()
      }, {
        headers: { Authorization: `Bearer ${disabledToken}` }
      });

      // Verificar que não foi salvo (se endpoint permitir)
      const analyticsRes = await axios.get(`${API_URL}/api/analytics/user/${disabledUserId}`, {
        headers: { Authorization: `Bearer ${disabledToken}` }
      });

      // Pode retornar vazio ou erro dependendo da implementação
    });
  });
});
