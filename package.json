{
  "name": "guia-aventureiro-automation",
  "version": "2.0.0",
  "description": "Testes automatizados para o Guia do Aventureiro",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "COVERAGE=true jest --coverage",
    "test:ci": "RETRY=true jest --verbose",
    "test:debug": "VERBOSE=true jest --watch",
    "test:quick": "jest --testPathIgnorePatterns=analytics|offline",
    "test:cleanup": "node scripts/verifyCleanup.js",
    "test:force-clean": "node scripts/forceCleanup.js",
    "test:report": "node scripts/generate-report.js",
    "screenshots": "node scripts/capture-screenshots-android.js",
    "emulator": "emulator -avd Pixel_5_API_33",
    "setup": "node scripts/setup-android-emulator.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "dotenv": "^16.3.1",
    "follow-redirects": "1.16.0",
    "mongoose": "^8.3.2"
  },
  "devDependencies": {
    "form-data": "^4.0.5",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0"
  }
}
